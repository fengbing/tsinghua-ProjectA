ExportedObj/
.vs/
.gradle/
/Assets/Plugins/Android/mainTemplate.gradle
/Assets/Plugins/Android/launcherTemplate.gradle
/Assets/Plugins/Android/gradleTemplate.properties
/[Aa]ssetCleanUpLog.xml
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# --- 系统生成的临时文件 ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

